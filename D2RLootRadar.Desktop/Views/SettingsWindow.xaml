<Window x:Class="D2RLootRadar.Desktop.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings"
        Height="460" Width="380"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen">
  <Window.Resources>

    <!-- Small circular "i" badge. Content-agnostic: each usage supplies its own ToolTip,
         so the visual style stays in one place while the help text stays local to the setting it explains. -->
    <Style x:Key="HelpIconBadgeStyle" TargetType="Border">
      <Setter Property="Width" Value="15" />
      <Setter Property="Height" Value="15" />
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="Background" Value="#FF5A5A5A" />
      <Setter Property="Margin" Value="6,0,0,0" />
      <Setter Property="Cursor" Value="Help" />
      <Setter Property="ToolTipService.InitialShowDelay" Value="150" />
      <Setter Property="ToolTipService.Placement" Value="Right" />
    </Style>

    <Style x:Key="HelpIconGlyphStyle" TargetType="TextBlock">
      <Setter Property="Text" Value="i" />
      <Setter Property="FontSize" Value="10" />
      <Setter Property="FontWeight" Value="Bold" />
      <Setter Property="Foreground" Value="White" />
      <Setter Property="HorizontalAlignment" Value="Center" />
      <Setter Property="VerticalAlignment" Value="Center" />
      <Setter Property="IsHitTestVisible" Value="False" />
    </Style>

    <!-- Wraps long tooltip text at a readable width instead of stretching across the screen. -->
    <Style x:Key="HelpTooltipTextStyle" TargetType="TextBlock">
      <Setter Property="TextWrapping" Value="Wrap" />
      <Setter Property="MaxWidth" Value="240" />
    </Style>

  </Window.Resources>
  <StackPanel Margin="20">

    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
      <TextBlock Text="Beep Volume" FontWeight="Medium" />
      <Border Style="{StaticResource HelpIconBadgeStyle}">
        <Border.ToolTip>
          <ToolTip>
            <TextBlock Style="{StaticResource HelpTooltipTextStyle}"
                       Text="How loud the alert tone plays, as a percentage. Setting this to 0 mutes the alert completely - no sound will attempt to play." />
          </ToolTip>
        </Border.ToolTip>
        <TextBlock Style="{StaticResource HelpIconGlyphStyle}" />
      </Border>
    </StackPanel>
    <Grid>
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="50" />
      </Grid.ColumnDefinitions>
      <Slider Grid.Column="0"
              Minimum="0" Maximum="100"
              Value="{Binding BeepVolume}"
              TickFrequency="10" />
      <TextBlock Grid.Column="1"
                 Text="{Binding BeepVolume, StringFormat={}{0}%}"
                 VerticalAlignment="Center"
                 HorizontalAlignment="Right" />
    </Grid>

    <StackPanel Orientation="Horizontal" Margin="0,16,0,4">
      <TextBlock Text="Beep Frequency" FontWeight="Medium" />
      <Border Style="{StaticResource HelpIconBadgeStyle}">
        <Border.ToolTip>
          <ToolTip>
            <TextBlock Style="{StaticResource HelpTooltipTextStyle}"
                       Text="The pitch of the alert tone in Hertz. Lower values sound deeper, higher values sound sharper. Range: 200-2000 Hz." />
          </ToolTip>
        </Border.ToolTip>
        <TextBlock Style="{StaticResource HelpIconGlyphStyle}" />
      </Border>
    </StackPanel>
    <Grid>
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="50" />
      </Grid.ColumnDefinitions>
      <Slider Grid.Column="0"
              Minimum="200" Maximum="2000"
              Value="{Binding BeepFrequencyHz}"
              TickFrequency="100" />
      <TextBlock Grid.Column="1"
                 Text="{Binding BeepFrequencyHz, StringFormat={}{0}Hz}"
                 VerticalAlignment="Center"
                 HorizontalAlignment="Right" />
    </Grid>

    <StackPanel Orientation="Horizontal" Margin="0,16,0,4">
      <TextBlock Text="Beep Duration" FontWeight="Medium" />
      <Border Style="{StaticResource HelpIconBadgeStyle}">
        <Border.ToolTip>
          <ToolTip>
            <TextBlock Style="{StaticResource HelpTooltipTextStyle}"
                       Text="How long the alert tone plays, in milliseconds. Longer isn't necessarily more noticeable - a short, sharp beep is often easier to place than a long one." />
          </ToolTip>
        </Border.ToolTip>
        <TextBlock Style="{StaticResource HelpIconGlyphStyle}" />
      </Border>
    </StackPanel>
    <Grid>
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="50" />
      </Grid.ColumnDefinitions>
      <Slider Grid.Column="0"
              Minimum="0" Maximum="1000"
              Value="{Binding BeepDurationMs}"
              TickFrequency="50" />
      <TextBlock Grid.Column="1"
                 Text="{Binding BeepDurationMs, StringFormat={}{0}ms}"
                 VerticalAlignment="Center"
                 HorizontalAlignment="Right" />
    </Grid>

    <Button Content="Test Sound"
            Command="{Binding TestSoundCommand}"
            HorizontalAlignment="Left"
            Margin="0,8,0,0"
            Padding="14,4" />

    <Separator Margin="0,20,0,16" />

    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
      <TextBlock Text="Match Sensitivity" FontWeight="Medium" />
      <Border Style="{StaticResource HelpIconBadgeStyle}">
        <Border.ToolTip>
          <ToolTip>
            <TextBlock Style="{StaticResource HelpTooltipTextStyle}"
                       Text="How closely OCR'd text must resemble a watched item's name to trigger an alert. Higher is stricter - fewer false alerts, but more likely to miss a badly misread label. Lower is more forgiving of OCR misreads, but more prone to false positives." />
          </ToolTip>
        </Border.ToolTip>
        <TextBlock Style="{StaticResource HelpIconGlyphStyle}" />
      </Border>
    </StackPanel>
    <Grid>
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="50" />
      </Grid.ColumnDefinitions>
      <Slider Grid.Column="0"
              Minimum="0.50" Maximum="1.00"
              Value="{Binding FuzzyMatchThreshold}"
              TickFrequency="0.05" />
      <TextBlock Grid.Column="1"
                 Text="{Binding FuzzyMatchThreshold, StringFormat={}{0:P0}}"
                 VerticalAlignment="Center"
                 HorizontalAlignment="Right" />
    </Grid>

    <StackPanel Orientation="Horizontal" Margin="0,16,0,4">
      <TextBlock Text="Marker Display Time" FontWeight="Medium" />
      <Border Style="{StaticResource HelpIconBadgeStyle}">
        <Border.ToolTip>
          <ToolTip>
            <TextBlock Style="{StaticResource HelpTooltipTextStyle}"
                       Text="How long the on-screen marker stays visible after a detection, or until the next detection. Keep this short - the marker doesn't track the item if you move the camera after it appears, so a longer display time gives it more time to drift from the item's actual position." />
          </ToolTip>
        </Border.ToolTip>
        <TextBlock Style="{StaticResource HelpIconGlyphStyle}" />
      </Border>
    </StackPanel>
    <Grid>
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="50" />
      </Grid.ColumnDefinitions>
      <Slider Grid.Column="0"
              Minimum="1" Maximum="10"
              Value="{Binding MarkerDisplaySeconds}"
              TickFrequency="1"
              IsSnapToTickEnabled="True" />
      <TextBlock Grid.Column="1"
                 Text="{Binding MarkerDisplaySeconds, StringFormat={}{0}s}"
                 VerticalAlignment="Center"
                 HorizontalAlignment="Right" />
    </Grid>

    <Separator Margin="0,20,0,16" />

    <StackPanel Orientation="Horizontal" Margin="0,16,0,4">
      <CheckBox Content="Show overlay on detection"
                IsChecked="{Binding OverlayEnabled}" />
      <Border Style="{StaticResource HelpIconBadgeStyle}">
        <Border.ToolTip>
          <ToolTip>
            <TextBlock Style="{StaticResource HelpTooltipTextStyle}"
                       Text="Shows a pulsing marker over each matched item for 5 seconds after each ALT press, or until the next detection. Click-through and can't be moved - it never interferes with mouse input in the game underneath." />
          </ToolTip>
        </Border.ToolTip>
        <TextBlock Style="{StaticResource HelpIconGlyphStyle}" />
      </Border>
    </StackPanel>

  </StackPanel>
</Window>