<Window x:Class="D2RLootRadar.Desktop.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:D2RLootRadar.Desktop.ViewModels"
        xmlns:conv="clr-namespace:D2RLootRadar.Desktop.Converters"
        Title="D2R Loot Radar"
        Height="540" Width="730"
        MinHeight="400" MinWidth="500"
        ResizeMode="CanResizeWithGrip"
        Icon="/Assets/d2rlootradar.ico">

  <Window.Resources>
    <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
    <conv:InverseBooleanToVisibilityConverter x:Key="InverseBoolToVisibility" />

    <!-- Rarity label colors, matching D2R's actual on-screen label colors -
         reused for both the popup's option rows and the toggle's summary dots. -->
    <SolidColorBrush x:Key="RarityNormalBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="RarityEtherealSocketedBrush" Color="#A0A0A0" />
    <SolidColorBrush x:Key="RarityMagicBrush" Color="#5A5AFF" />
    <SolidColorBrush x:Key="RarityRareBrush" Color="#FFFF64" />
    <SolidColorBrush x:Key="RaritySetBrush" Color="#31DE2F" />
    <SolidColorBrush x:Key="RarityUniqueBrush" Color="#C7BB95" />
    <!-- Measured from real in-game label captures (Rune/Material orange, Shard red) -
         Rune/Gem/Material are single-rarity bases with no popup, so these were never needed
         there; the summary panel is the first place they actually render. -->
    <SolidColorBrush x:Key="RarityRuneMaterialBrush" Color="#D79F05" />
    <SolidColorBrush x:Key="RarityShardBrush" Color="#DA5C5C" />
    <!-- Superior has no label color of its own (it's a text prefix) - a neutral square
         instead of a colored circle keeps it visually distinct from the six real colors. -->
    <SolidColorBrush x:Key="RaritySuperiorBrush" Color="#888888" />

    <!-- Flat clickable button: no chrome, transparent background, fills its grid cell. -->
    <Style x:Key="FlatButton" TargetType="Button">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="FocusVisualStyle" Value="{x:Null}" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border Background="{TemplateBinding Background}"
                    Padding="{TemplateBinding Padding}">
              <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background"
                        Value="{DynamicResource {x:Static SystemColors.ControlLightBrushKey}}" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- Rarity picker's closed-state button: flat, bordered, fills with the summary dots. -->
    <Style x:Key="RaritySummaryToggle" TargetType="ToggleButton">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="{DynamicResource {x:Static SystemColors.ControlLightBrushKey}}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="FocusVisualStyle" Value="{x:Null}" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="ToggleButton">
            <Border Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="3">
              <ContentPresenter Margin="6,2" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background"
                        Value="{DynamicResource {x:Static SystemColors.ControlLightBrushKey}}" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- One row inside the rarity popup: colored swatch + name, full-row click target. -->
    <Style x:Key="RarityOptionRow" TargetType="CheckBox">
      <Setter Property="Padding" Value="6,0,0,0" />
      <Setter Property="Height" Value="24" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>
  </Window.Resources>

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <!-- Titlebar -->
    <Border Grid.Row="0"
            BorderBrush="{DynamicResource {x:Static SystemColors.ControlLightBrushKey}}"
            BorderThickness="0,0,0,1"
            Padding="14,8">
      <Grid>
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">

          <!-- Game status indicator -->
          <Ellipse Width="8" Height="8" VerticalAlignment="Center">
            <Ellipse.Style>
              <Style TargetType="Ellipse">
                <Setter Property="Fill" Value="#888888"/>
                <Style.Triggers>
                  <DataTrigger Binding="{Binding IsGameRunning}" Value="True">
                    <Setter Property="Fill" Value="#3B6D11" />
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </Ellipse.Style>
          </Ellipse>

          <TextBlock Margin="8,0,0,0" FontSize="12" VerticalAlignment="Center">
            <TextBlock.Style>
              <Style TargetType="TextBlock">
                <Setter Property="Text" Value="D2R not running" />
                <Setter Property="Foreground" Value="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}" />
                <Style.Triggers>
                  <DataTrigger Binding="{Binding IsGameRunning}" Value="True">
                    <Setter Property="Text" Value="D2R running" />
                    <Setter Property="Foreground" Value="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}"/>
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </TextBlock.Style>
          </TextBlock>

          <TextBlock Margin="8,0,0,0"
                     Text="·"
                     FontSize="12"
                     Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                     VerticalAlignment="Center" />

          <TextBlock Margin="8,0,0,0"
                     Text="D2R Loot Radar"
                     FontWeight="Medium"
                     FontSize="13"
                     VerticalAlignment="Center" />

        </StackPanel>

        <Button Content="Settings"
                Command="{Binding OpenSettingsCommand}"
                HorizontalAlignment="Right"
                VerticalAlignment="Center"
                Padding="14,4"
                FontSize="12" />

      </Grid>
    </Border>

    <!-- Search bar -->
    <Border Grid.Row="1"
            BorderBrush="{DynamicResource {x:Static SystemColors.ControlLightBrushKey}}"
            BorderThickness="0,0,0,1"
            Padding="14,8">
      <Grid>
        <TextBox x:Name="SearchBox"
                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                 Padding="6,4,26,4"
                 FontSize="12"
                 VerticalContentAlignment="Center" />

        <!-- Placeholder - overlaid rather than a native watermark (TextBox has none),
             hidden as soon as there's any text and never intercepts clicks itself,
             so it can't get in the way of focusing or selecting inside the box below it. -->
        <TextBlock Text="Search items…"
                   FontSize="12"
                   Margin="9,0,0,0"
                   VerticalAlignment="Center"
                   IsHitTestVisible="False"
                   Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                   Visibility="{Binding HasSearchText, Converter={StaticResource InverseBoolToVisibility}}" />

        <!-- Clear button - only shown once there's something to clear. -->
        <Button Content="✕"
                Command="{Binding ClearSearchCommand}"
                Style="{StaticResource FlatButton}"
                HorizontalAlignment="Right"
                Width="22"
                FontSize="11"
                Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                Visibility="{Binding HasSearchText, Converter={StaticResource BoolToVisibility}}" />
      </Grid>
    </Border>

    <!-- Body -->
    <Grid Grid.Row="2">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" MinWidth="200" />
        <ColumnDefinition Width="6" />
        <ColumnDefinition Width="260" MinWidth="160" MaxWidth="400" />
      </Grid.ColumnDefinitions>

      <!-- Left: category list -->
      <ScrollViewer Grid.Column="0"
                    VerticalScrollBarVisibility="Auto"
                    HorizontalScrollBarVisibility="Disabled">
        <ItemsControl ItemsSource="{Binding Categories}">
          <ItemsControl.ItemTemplate>
            <DataTemplate DataType="{x:Type vm:CategoryViewModel}">
              <Border BorderBrush="{DynamicResource {x:Static SystemColors.ControlLightBrushKey}}"
                      BorderThickness="0,0,0,1"
                      Visibility="{Binding IsVisible, Converter={StaticResource BoolToVisibility}}">
                <StackPanel>

                  <!-- Category header row -->
                  <Grid Height="34">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="Auto" />
                      <ColumnDefinition Width="*" />
                      <ColumnDefinition Width="32" />
                    </Grid.ColumnDefinitions>

                    <!-- Select / deselect all -->
                    <CheckBox Grid.Column="0"
                              IsChecked="{Binding AllSelected}"
                              IsThreeState="False"
                              VerticalAlignment="Center"
                              Margin="10,0,6,0" />

                    <!-- Expand toggle: name + count badge -->
                    <Button Grid.Column="1"
                            Command="{Binding ToggleExpandedCommand}"
                            Style="{StaticResource FlatButton}"
                            HorizontalContentAlignment="Left"
                            Height="34">
                      <StackPanel Orientation="Horizontal"
                                  VerticalAlignment="Center"
                                  Margin="2,0,0,0">
                        <TextBlock Text="{Binding Name}"
                                   FontSize="11"
                                   FontWeight="Medium"
                                   Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                                   VerticalAlignment="Center" />

                        <!-- Count badge -->
                        <Border Margin="7,0,0,0"
                                CornerRadius="10"
                                Padding="7,1"
                                BorderThickness="1"
                                VerticalAlignment="Center">
                          <Border.Style>
                            <Style TargetType="Border">
                              <Setter Property="Background" Value="{DynamicResource {x:Static SystemColors.ControlLightBrushKey}}" />
                              <Setter Property="BorderBrush" Value="{DynamicResource {x:Static SystemColors.ControlLightBrushKey}}" />
                              <Style.Triggers>
                                <DataTrigger Binding="{Binding HasSelection}" Value="True">
                                  <Setter Property="Background"  Value="#E6F1FB" />
                                  <Setter Property="BorderBrush" Value="#B5D4F4" />
                                </DataTrigger>
                              </Style.Triggers>
                            </Style>
                          </Border.Style>
                          <TextBlock Text="{Binding CountLabel}" FontSize="11">
                            <TextBlock.Style>
                              <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}" />
                                <Style.Triggers>
                                  <DataTrigger Binding="{Binding HasSelection}" Value="True">
                                    <Setter Property="Foreground" Value="#185FA5" />
                                  </DataTrigger>
                                </Style.Triggers>
                              </Style>
                            </TextBlock.Style>
                          </TextBlock>
                        </Border>
                      </StackPanel>
                    </Button>

                    <!-- Chevron -->
                    <Button Grid.Column="2"
                            Command="{Binding ToggleExpandedCommand}"
                            Style="{StaticResource FlatButton}"
                            Height="34">
                      <TextBlock FontSize="11"
                                 HorizontalAlignment="Center"
                                 VerticalAlignment="Center"
                                 Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}">
                        <TextBlock.Style>
                          <Style TargetType="TextBlock">
                            <Setter Property="Text" Value="▾" />
                            <Style.Triggers>
                              <DataTrigger Binding="{Binding IsExpanded}" Value="True">
                                <Setter Property="Text" Value="▴" />
                              </DataTrigger>
                            </Style.Triggers>
                          </Style>
                        </TextBlock.Style>
                      </TextBlock>
                    </Button>
                  </Grid>

                  <!-- Item rows (shown when expanded).
                       VirtualizingStackPanel + IsVirtualizing="True" instead of the default StackPanel:
                       a plain ItemsControl generates every item's container as soon as ItemsSource is
                       bound, regardless of Visibility - so with ~600 items total across all categories,
                       each now carrying a Popup-based rarity picker or info-icon tooltip, every row in
                       every category (including ones never expanded) was being built at startup.
                       Virtualization defers container generation to the Measure pass instead, and a
                       Collapsed element never gets measured - so a collapsed category now realizes zero
                       row containers until the first time it's actually expanded.
                       VirtualizationMode="Standard" (discard, not recycle) rather than "Recycling" -
                       deliberately, given each row's Popup carries its own open/closed state
                       (ItemBaseViewModel.IsPopupOpen); recycling containers across different
                       ItemBaseViewModels risks that state bleeding from one item's row into another's
                       after a scroll, which isn't worth the extra container-reuse savings here. -->
                  <ItemsControl ItemsSource="{Binding Items}"
                                Visibility="{Binding IsExpanded, Converter={StaticResource BoolToVisibility}}"
                                VirtualizingPanel.IsVirtualizing="True"
                                VirtualizingPanel.VirtualizationMode="Standard"
                                VirtualizingPanel.ScrollUnit="Item">
                    <ItemsControl.ItemsPanel>
                      <ItemsPanelTemplate>
                        <VirtualizingStackPanel />
                      </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                      <DataTemplate DataType="{x:Type vm:ItemBaseViewModel}">
                        <Grid Margin="30,0,12,0" Height="26"
                              Visibility="{Binding IsVisible, Converter={StaticResource BoolToVisibility}}">
                          <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                          </Grid.ColumnDefinitions>

                          <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="{Binding Name}"
                                       FontSize="13"
                                       VerticalAlignment="Center" />

                            <!-- Info icon: only rendered when there's actually something to show -
                                 a plain, unsocketable base with no Set/Unique version gets no icon at all. -->
                            <TextBlock Text="&#9432;"
                                       FontSize="13"
                                       Margin="6,0,0,0"
                                       VerticalAlignment="Center"
                                       Cursor="Help"
                                       Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                                       Visibility="{Binding HasInfo, Converter={StaticResource BoolToVisibility}}">
                              <TextBlock.ToolTip>
                                <ToolTip Background="#1E1B18">
                                  <StackPanel>
                                    <TextBlock FontSize="12"
                                               Foreground="White"
                                               Visibility="{Binding HasMaxSockets, Converter={StaticResource BoolToVisibility}}">
                                      <Run Text="Max Sockets: " />
                                      <Run Text="{Binding MaxSockets, Mode=OneWay}" />
                                    </TextBlock>
                                    <ItemsControl ItemsSource="{Binding SetVariants}">
                                      <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                          <TextBlock Text="{Binding}"
                                                   FontSize="12"
                                                   Foreground="#31DE2F" />
                                        </DataTemplate>
                                      </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <ItemsControl ItemsSource="{Binding UniqueVariants}">
                                      <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                          <TextBlock Text="{Binding}"
                                                   FontSize="12"
                                                   Foreground="#C7BB95" />
                                        </DataTemplate>
                                      </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                  </StackPanel>
                                </ToolTip>
                              </TextBlock.ToolTip>
                            </TextBlock>
                          </StackPanel>

                          <!-- Single-rarity bases (Rune/Gem/Material): plain watched/not-watched checkbox -
                               there's only one rarity they can ever appear as, so a picker would be pointless ceremony. -->
                          <CheckBox Grid.Column="1"
                                    IsChecked="{Binding AllRaritiesSelected}"
                                    IsThreeState="False"
                                    VerticalAlignment="Center">
                            <CheckBox.Style>
                              <Style TargetType="CheckBox">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                  <DataTrigger Binding="{Binding IsSingleRarity}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                  </DataTrigger>
                                </Style.Triggers>
                              </Style>
                            </CheckBox.Style>
                          </CheckBox>

                          <!-- Multi-rarity bases: popup rarity picker, one checkbox per applicable rarity, stackable. -->
                          <Grid Grid.Column="1" VerticalAlignment="Center">
                            <Grid.Style>
                              <Style TargetType="Grid">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                  <DataTrigger Binding="{Binding IsSingleRarity}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                  </DataTrigger>
                                </Style.Triggers>
                              </Style>
                            </Grid.Style>

                            <ToggleButton x:Name="RarityToggle"
                                          IsChecked="{Binding IsPopupOpen, Mode=TwoWay}"
                                          Style="{StaticResource RaritySummaryToggle}">
                              <StackPanel Orientation="Horizontal">
                                <!-- Summary dots: one per currently-selected rarity, same colors used inside the popup. -->
                                <Ellipse Width="7" Height="7" Margin="1,0" VerticalAlignment="Center"
                                         Fill="{StaticResource RarityNormalBrush}"
                                         Stroke="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}"
                                         StrokeThickness="1"
                                         Visibility="{Binding IsNormalSelected, Converter={StaticResource BoolToVisibility}}" />
                                <Ellipse Width="7" Height="7" Margin="1,0" VerticalAlignment="Center"
                                         Fill="{StaticResource RarityEtherealSocketedBrush}"
                                         Visibility="{Binding IsEtherealSocketedSelected, Converter={StaticResource BoolToVisibility}}" />
                                <Ellipse Width="7" Height="7" Margin="1,0" VerticalAlignment="Center"
                                         Fill="{StaticResource RarityMagicBrush}"
                                         Visibility="{Binding IsMagicSelected, Converter={StaticResource BoolToVisibility}}" />
                                <Ellipse Width="7" Height="7" Margin="1,0" VerticalAlignment="Center"
                                         Fill="{StaticResource RarityRareBrush}"
                                         Visibility="{Binding IsRareSelected, Converter={StaticResource BoolToVisibility}}" />
                                <Ellipse Width="7" Height="7" Margin="1,0" VerticalAlignment="Center"
                                         Fill="{StaticResource RaritySetBrush}"
                                         Visibility="{Binding IsSetSelected, Converter={StaticResource BoolToVisibility}}" />
                                <Ellipse Width="7" Height="7" Margin="1,0" VerticalAlignment="Center"
                                         Fill="{StaticResource RarityUniqueBrush}"
                                         Visibility="{Binding IsUniqueSelected, Converter={StaticResource BoolToVisibility}}" />
                                <Rectangle Width="7" Height="7" Margin="1,0" VerticalAlignment="Center"
                                           Fill="{StaticResource RaritySuperiorBrush}"
                                           Visibility="{Binding IsSuperiorSelected, Converter={StaticResource BoolToVisibility}}" />

                                <TextBlock Text="None"
                                           FontSize="11"
                                           Margin="2,0,0,0"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                                           Visibility="{Binding HasAnySelection, Converter={StaticResource InverseBoolToVisibility}}" />

                                <TextBlock Text="▾"
                                           FontSize="9"
                                           Margin="5,0,0,0"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}" />
                              </StackPanel>
                            </ToggleButton>

                            <Popup PlacementTarget="{Binding ElementName=RarityToggle}"
                                   Placement="Bottom"
                                   StaysOpen="False"
                                   AllowsTransparency="True"
                                   IsOpen="{Binding IsPopupOpen, Mode=TwoWay}">
                              <Border Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}"
                                      BorderBrush="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}"
                                      BorderThickness="1"
                                      CornerRadius="4"
                                      Padding="4"
                                      Margin="0,2,0,0">
                                <StackPanel MinWidth="150">

                                  <CheckBox Style="{StaticResource RarityOptionRow}"
                                            IsChecked="{Binding IsNormalSelected}"
                                            Visibility="{Binding ShowNormal, Converter={StaticResource BoolToVisibility}}">
                                    <StackPanel Orientation="Horizontal">
                                      <Ellipse Width="8" Height="8" Fill="{StaticResource RarityNormalBrush}"
                                               Stroke="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}"
                                               StrokeThickness="1" VerticalAlignment="Center" />
                                      <TextBlock Text="Normal" FontSize="12" Margin="6,0,0,0" VerticalAlignment="Center" />
                                    </StackPanel>
                                  </CheckBox>

                                  <CheckBox Style="{StaticResource RarityOptionRow}"
                                            IsChecked="{Binding IsEtherealSocketedSelected}"
                                            Visibility="{Binding ShowEtheralSocketed, Converter={StaticResource BoolToVisibility}}">
                                    <StackPanel Orientation="Horizontal">
                                      <Ellipse Width="8" Height="8" Fill="{StaticResource RarityEtherealSocketedBrush}" VerticalAlignment="Center" />
                                      <TextBlock Text="Ethereal / Socketed" FontSize="12" Margin="6,0,0,0" VerticalAlignment="Center" />
                                    </StackPanel>
                                  </CheckBox>

                                  <CheckBox Style="{StaticResource RarityOptionRow}"
                                            IsChecked="{Binding IsMagicSelected}"
                                            Visibility="{Binding ShowMagic, Converter={StaticResource BoolToVisibility}}">
                                    <StackPanel Orientation="Horizontal">
                                      <Ellipse Width="8" Height="8" Fill="{StaticResource RarityMagicBrush}" VerticalAlignment="Center" />
                                      <TextBlock Text="Magic" FontSize="12" Margin="6,0,0,0" VerticalAlignment="Center" />
                                    </StackPanel>
                                  </CheckBox>

                                  <CheckBox Style="{StaticResource RarityOptionRow}"
                                            IsChecked="{Binding IsRareSelected}"
                                            Visibility="{Binding ShowRare, Converter={StaticResource BoolToVisibility}}">
                                    <StackPanel Orientation="Horizontal">
                                      <Ellipse Width="8" Height="8" Fill="{StaticResource RarityRareBrush}" VerticalAlignment="Center" />
                                      <TextBlock Text="Rare" FontSize="12" Margin="6,0,0,0" VerticalAlignment="Center" />
                                    </StackPanel>
                                  </CheckBox>

                                  <CheckBox Style="{StaticResource RarityOptionRow}"
                                            IsChecked="{Binding IsSetSelected}"
                                            Visibility="{Binding ShowSet, Converter={StaticResource BoolToVisibility}}">
                                    <StackPanel Orientation="Horizontal">
                                      <Ellipse Width="8" Height="8" Fill="{StaticResource RaritySetBrush}" VerticalAlignment="Center" />
                                      <TextBlock Text="Set" FontSize="12" Margin="6,0,0,0" VerticalAlignment="Center" />
                                    </StackPanel>
                                  </CheckBox>

                                  <CheckBox Style="{StaticResource RarityOptionRow}"
                                            IsChecked="{Binding IsUniqueSelected}"
                                            Visibility="{Binding ShowUnique, Converter={StaticResource BoolToVisibility}}">
                                    <StackPanel Orientation="Horizontal">
                                      <Ellipse Width="8" Height="8" Fill="{StaticResource RarityUniqueBrush}" VerticalAlignment="Center" />
                                      <TextBlock Text="Unique" FontSize="12" Margin="6,0,0,0" VerticalAlignment="Center" />
                                    </StackPanel>
                                  </CheckBox>

                                  <CheckBox Style="{StaticResource RarityOptionRow}"
                                            IsChecked="{Binding IsSuperiorSelected}"
                                            Visibility="{Binding ShowSuperior, Converter={StaticResource BoolToVisibility}}">
                                    <StackPanel Orientation="Horizontal">
                                      <Rectangle Width="8" Height="8" Fill="{StaticResource RaritySuperiorBrush}" VerticalAlignment="Center" />
                                      <TextBlock Text="Superior" FontSize="12" Margin="6,0,0,0" VerticalAlignment="Center" />
                                    </StackPanel>
                                  </CheckBox>

                                  <Separator Margin="0,4" />

                                  <CheckBox Style="{StaticResource RarityOptionRow}"
                                            IsChecked="{Binding AllRaritiesSelected}"
                                            IsThreeState="False"
                                            Content="Select all" FontSize="12" FontWeight="Medium" />

                                </StackPanel>
                              </Border>
                            </Popup>
                          </Grid>
                        </Grid>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>

                </StackPanel>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </ScrollViewer>

      <!-- Column divider - draggable to resize the left/right split.
           ResizeBehavior="PreviousAndNext" grows one side exactly as much as it shrinks the other,
           so dragging doesn't change the window's total width. -->
      <GridSplitter Grid.Column="1"
                     Width="6"
                     HorizontalAlignment="Stretch"
                     VerticalAlignment="Stretch"
                     ResizeDirection="Columns"
                     ResizeBehavior="PreviousAndNext"
                     Background="{DynamicResource {x:Static SystemColors.ControlLightBrushKey}}"
                     Cursor="SizeWE" />

      <!-- Right: summary panel -->
      <Grid Grid.Column="2">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Summary header -->
        <Border Grid.Row="0"
                BorderBrush="{DynamicResource {x:Static SystemColors.ControlLightBrushKey}}"
                BorderThickness="0,0,0,1"
                Padding="14,9">
          <Grid>
            <TextBlock Text="WATCH LIST"
                       FontSize="11"
                       FontWeight="Medium"
                       Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                       VerticalAlignment="Center" />
            <TextBlock HorizontalAlignment="Right"
                       FontSize="11"
                       Foreground="#185FA5"
                       VerticalAlignment="Center">
              <TextBlock.Style>
                <Style TargetType="TextBlock">
                  <Style.Triggers>
                    <DataTrigger Binding="{Binding TotalSelectedCount}" Value="0">
                      <Setter Property="Visibility" Value="Collapsed" />
                    </DataTrigger>
                  </Style.Triggers>
                </Style>
              </TextBlock.Style>
                <Run Text="{Binding TotalSelectedCount, Mode=OneWay}" />
                <Run Text=" selected" />
            </TextBlock>
          </Grid>
        </Border>

        <!-- Summary body -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
          <StackPanel>

            <!-- Empty state -->
            <TextBlock Padding="14,24,14,0"
                       FontSize="12"
                       TextAlignment="Center"
                       TextWrapping="Wrap"
                       Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                       Text="No items selected. Check items on the left to build your watch list.">
              <TextBlock.Style>
                <Style TargetType="TextBlock">
                  <Setter Property="Visibility" Value="Collapsed" />
                  <Style.Triggers>
                    <DataTrigger Binding="{Binding TotalSelectedCount}" Value="0">
                      <Setter Property="Visibility" Value="Visible" />
                    </DataTrigger>
                  </Style.Triggers>
                </Style>
              </TextBlock.Style>
            </TextBlock>

            <!-- Selected groups -->
            <ItemsControl ItemsSource="{Binding Summary}">
              <ItemsControl.ItemTemplate>
                <DataTemplate DataType="{x:Type vm:SummaryCategoryViewModel}">
                  <StackPanel Margin="0,8,0,4">
                    <TextBlock Text="{Binding Name}"
                               FontSize="10"
                               FontWeight="Medium"
                               Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                               Margin="14,0,14,3" />
                    <ItemsControl ItemsSource="{Binding Items}">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:SummaryItemViewModel}">
                          <Grid Margin="14,2,14,2">
                            <Grid.ColumnDefinitions>
                              <ColumnDefinition Width="120" />
                              <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Orientation="Horizontal">
                              <Ellipse Width="3"
                                       Height="3"
                                       Fill="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                                       VerticalAlignment="Center"
                                       Margin="0,0,7,0" />
                              <TextBlock Text="{Binding Name}"
                                         FontSize="12"
                                         VerticalAlignment="Center"
                                         TextTrimming="CharacterEllipsis" />
                            </StackPanel>

                            <!-- Selected-rarity dots - same colors as the watch-list's rarity picker,
                                 reflecting what's actually selected, not what's merely applicable.
                                 Column 1 keeps this aligned to the same X across every row,
                                 regardless of name length, so the dots read as a scannable column. -->
                            <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="10,0,0,0">
                              <Ellipse Width="6" Height="6" Margin="0,0,6,0" VerticalAlignment="Center"
                                       Fill="{StaticResource RarityNormalBrush}"
                                       Stroke="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}"
                                       StrokeThickness="1"
                                       Visibility="{Binding ShowNormal, Converter={StaticResource BoolToVisibility}}" />
                              <Ellipse Width="6" Height="6" Margin="0,0,6,0" VerticalAlignment="Center"
                                       Fill="{StaticResource RarityEtherealSocketedBrush}"
                                       Visibility="{Binding ShowEtherealSocketed, Converter={StaticResource BoolToVisibility}}" />
                              <Ellipse Width="6" Height="6" Margin="0,0,6,0" VerticalAlignment="Center"
                                       Fill="{StaticResource RarityMagicBrush}"
                                       Visibility="{Binding ShowMagic, Converter={StaticResource BoolToVisibility}}" />
                              <Ellipse Width="6" Height="6" Margin="0,0,6,0" VerticalAlignment="Center"
                                       Fill="{StaticResource RarityRareBrush}"
                                       Visibility="{Binding ShowRare, Converter={StaticResource BoolToVisibility}}" />
                              <Ellipse Width="6" Height="6" Margin="0,0,6,0" VerticalAlignment="Center"
                                       Fill="{StaticResource RaritySetBrush}"
                                       Visibility="{Binding ShowSet, Converter={StaticResource BoolToVisibility}}" />
                              <Ellipse Width="6" Height="6" Margin="0,0,6,0" VerticalAlignment="Center"
                                       Fill="{StaticResource RarityUniqueBrush}"
                                       Visibility="{Binding ShowUnique, Converter={StaticResource BoolToVisibility}}" />
                              <Ellipse Width="6" Height="6" Margin="0,0,6,0" VerticalAlignment="Center"
                                       Fill="{StaticResource RarityRuneMaterialBrush}"
                                       Visibility="{Binding ShowRuneMaterial, Converter={StaticResource BoolToVisibility}}" />
                              <Ellipse Width="6" Height="6" Margin="0,0,6,0" VerticalAlignment="Center"
                                       Fill="{StaticResource RarityShardBrush}"
                                       Visibility="{Binding ShowShard, Converter={StaticResource BoolToVisibility}}" />
                              <Rectangle Width="6" Height="6" Margin="0,0,6,0" VerticalAlignment="Center"
                                         Fill="{StaticResource RaritySuperiorBrush}"
                                         Visibility="{Binding ShowSuperior, Converter={StaticResource BoolToVisibility}}" />
                            </StackPanel>
                          </Grid>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </StackPanel>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>

          </StackPanel>
        </ScrollViewer>
      </Grid>
    </Grid>
  </Grid>
</Window>