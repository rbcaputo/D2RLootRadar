<Window x:Class="D2RLootRadar.Desktop.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:D2RLootRadar.Desktop.ViewModels"
        Title="D2R Loot Radar"
        Height="540" Width="700"
        MinHeight="400" MinWidth="500"
        ResizeMode="CanResizeWithGrip">

  <Window.Resources>
    <BooleanToVisibilityConverter x:Key="BoolToVisibility" />

    <!-- Flat clickable button: no chrome, transparent bg, fills its grid cell -->
    <Style x:Key="FlatButton" TargetType="Button">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="FocusVisualStyle" Value="{x:Null}" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border Background="{TemplateBinding Background}"
                    Padding="{TemplateBinding Padding}">
              <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background"
                        Value="{DynamicResource {x:Static SystemColors.ControlLightBrushKey}}" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
  </Window.Resources>

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <!-- Titlebar -->
    <Border Grid.Row="0"
            BorderBrush="{DynamicResource {x:Static SystemColors.ControlLightBrushKey}}"
            BorderThickness="0,0,0,1"
            Padding="14,8">
      <Grid>
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">

          <!-- Game status indicator -->
          <Ellipse Width="8" Height="8" VerticalAlignment="Center">
            <Ellipse.Style>
              <Style TargetType="Ellipse">
                <Setter Property="Fill" Value="#888888"/>
                <Style.Triggers>
                  <DataTrigger Binding="{Binding IsGameRunning}" Value="True">
                    <Setter Property="Fill" Value="#3B6D11" />
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </Ellipse.Style>
          </Ellipse>

          <TextBlock Margin="8,0,0,0" FontSize="12" VerticalAlignment="Center">
            <TextBlock.Style>
              <Style TargetType="TextBlock">
                <Setter Property="Text" Value="D2R not running" />
                <Setter Property="Foreground" Value="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}" />
                <Style.Triggers>
                  <DataTrigger Binding="{Binding IsGameRunning}" Value="True">
                    <Setter Property="Text" Value="D2R running" />
                    <Setter Property="Foreground" Value="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}"/>
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </TextBlock.Style>
          </TextBlock>

          <TextBlock Margin="8,0,0,0"
                     Text="·"
                     FontSize="12"
                     Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                     VerticalAlignment="Center" />

          <TextBlock Margin="8,0,0,0"
                     Text="D2R Loot Beeper"
                     FontWeight="Medium"
                     FontSize="13"
                     VerticalAlignment="Center" />

        </StackPanel>

        <Button Content="Settings"
                Command="{Binding OpenSettingsCommand}"
                HorizontalAlignment="Right"
                VerticalAlignment="Center"
                Padding="14,4"
                FontSize="12" />

      </Grid>
    </Border>

    <!-- Body -->
    <Grid Grid.Row="1">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" MinWidth="200" />
        <ColumnDefinition Width="1" />
        <ColumnDefinition Width="220" MinWidth="160" />
      </Grid.ColumnDefinitions>

      <!-- Left: category list -->
      <ScrollViewer Grid.Column="0"
                    VerticalScrollBarVisibility="Auto"
                    HorizontalScrollBarVisibility="Disabled">
        <ItemsControl ItemsSource="{Binding Categories}">
          <ItemsControl.ItemTemplate>
            <DataTemplate DataType="{x:Type vm:CategoryViewModel}">
              <Border BorderBrush="{DynamicResource {x:Static SystemColors.ControlLightBrushKey}}"
                      BorderThickness="0,0,0,1">
                <StackPanel>

                  <!-- Category header row -->
                  <Grid Height="34">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="Auto" />
                      <ColumnDefinition Width="*" />
                      <ColumnDefinition Width="32" />
                    </Grid.ColumnDefinitions>

                    <!-- Select / deselect all -->
                    <CheckBox Grid.Column="0"
                              IsChecked="{Binding AllSelected}"
                              IsThreeState="False"
                              VerticalAlignment="Center"
                              Margin="10,0,6,0" />

                    <!-- Expand toggle: name + count badge -->
                    <Button Grid.Column="1"
                            Command="{Binding ToggleExpandedCommand}"
                            Style="{StaticResource FlatButton}"
                            HorizontalContentAlignment="Left"
                            Height="34">
                      <StackPanel Orientation="Horizontal"
                                  VerticalAlignment="Center"
                                  Margin="2,0,0,0">
                        <TextBlock Text="{Binding Name}"
                                   FontSize="11"
                                   FontWeight="Medium"
                                   Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                                   VerticalAlignment="Center" />

                        <!-- Count badge -->
                        <Border Margin="7,0,0,0"
                                CornerRadius="10"
                                Padding="7,1"
                                BorderThickness="1"
                                VerticalAlignment="Center">
                          <Border.Style>
                            <Style TargetType="Border">
                              <Setter Property="Background" Value="{DynamicResource {x:Static SystemColors.ControlLightBrushKey}}" />
                              <Setter Property="BorderBrush" Value="{DynamicResource {x:Static SystemColors.ControlLightBrushKey}}" />
                              <Style.Triggers>
                                <DataTrigger Binding="{Binding HasSelection}" Value="True">
                                  <Setter Property="Background"  Value="#E6F1FB" />
                                  <Setter Property="BorderBrush" Value="#B5D4F4" />
                                </DataTrigger>
                              </Style.Triggers>
                            </Style>
                          </Border.Style>
                          <TextBlock Text="{Binding CountLabel}" FontSize="11">
                            <TextBlock.Style>
                              <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}" />
                                <Style.Triggers>
                                  <DataTrigger Binding="{Binding HasSelection}" Value="True">
                                    <Setter Property="Foreground" Value="#185FA5" />
                                  </DataTrigger>
                                </Style.Triggers>
                              </Style>
                            </TextBlock.Style>
                          </TextBlock>
                        </Border>
                      </StackPanel>
                    </Button>

                    <!-- Chevron -->
                    <Button Grid.Column="2"
                            Command="{Binding ToggleExpandedCommand}"
                            Style="{StaticResource FlatButton}"
                            Height="34">
                      <TextBlock FontSize="11"
                                 HorizontalAlignment="Center"
                                 VerticalAlignment="Center"
                                 Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}">
                        <TextBlock.Style>
                          <Style TargetType="TextBlock">
                            <Setter Property="Text" Value="▾" />
                            <Style.Triggers>
                              <DataTrigger Binding="{Binding IsExpanded}" Value="True">
                                <Setter Property="Text" Value="▴" />
                              </DataTrigger>
                            </Style.Triggers>
                          </Style>
                        </TextBlock.Style>
                      </TextBlock>
                    </Button>
                  </Grid>

                  <!-- Item checkboxes (shown when expanded) -->
                  <ItemsControl ItemsSource="{Binding Items}"
                                Visibility="{Binding IsExpanded, Converter={StaticResource BoolToVisibility}}">
                    <ItemsControl.ItemTemplate>
                      <DataTemplate DataType="{x:Type vm:ItemBaseViewModel}">
                        <CheckBox IsChecked="{Binding IsSelected}"
                                  Margin="30,0,12,0"
                                  Padding="4,0,0,0"
                                  Height="26"
                                  VerticalContentAlignment="Center">
                          <TextBlock Text="{Binding Name}" FontSize="13" />
                        </CheckBox>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>

                </StackPanel>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </ScrollViewer>

      <!-- Column divider -->
      <Border Grid.Column="1"
              Background="{DynamicResource {x:Static SystemColors.ControlLightBrushKey}}" />

      <!-- Right: summary panel -->
      <Grid Grid.Column="2">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Summary header -->
        <Border Grid.Row="0"
                BorderBrush="{DynamicResource {x:Static SystemColors.ControlLightBrushKey}}"
                BorderThickness="0,0,0,1"
                Padding="14,9">
          <Grid>
            <TextBlock Text="WATCH LIST"
                       FontSize="11"
                       FontWeight="Medium"
                       Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                       VerticalAlignment="Center" />
            <TextBlock HorizontalAlignment="Right"
                       FontSize="11"
                       Foreground="#185FA5"
                       VerticalAlignment="Center">
              <TextBlock.Style>
                <Style TargetType="TextBlock">
                  <Style.Triggers>
                    <DataTrigger Binding="{Binding TotalSelectedCount}" Value="0">
                      <Setter Property="Visibility" Value="Collapsed" />
                    </DataTrigger>
                  </Style.Triggers>
                </Style>
              </TextBlock.Style>
                <Run Text="{Binding TotalSelectedCount, Mode=OneWay}" />
                <Run Text=" selected" />
            </TextBlock>
          </Grid>
        </Border>

        <!-- Summary body -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
          <StackPanel>

            <!-- Empty state -->
            <TextBlock Padding="14,24,14,0"
                       FontSize="12"
                       TextAlignment="Center"
                       TextWrapping="Wrap"
                       Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                       Text="No items selected. Check items on the left to build your watch list.">
              <TextBlock.Style>
                <Style TargetType="TextBlock">
                  <Setter Property="Visibility" Value="Collapsed" />
                  <Style.Triggers>
                    <DataTrigger Binding="{Binding TotalSelectedCount}" Value="0">
                      <Setter Property="Visibility" Value="Visible" />
                    </DataTrigger>
                  </Style.Triggers>
                </Style>
              </TextBlock.Style>
            </TextBlock>

            <!-- Selected groups -->
            <ItemsControl ItemsSource="{Binding Summary}">
              <ItemsControl.ItemTemplate>
                <DataTemplate DataType="{x:Type vm:SummaryCategoryViewModel}">
                  <StackPanel Margin="0,8,0,4">
                    <TextBlock Text="{Binding Name}"
                               FontSize="10"
                               FontWeight="Medium"
                               Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                               Margin="14,0,14,3" />
                    <ItemsControl ItemsSource="{Binding Items}">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate>
                          <StackPanel Orientation="Horizontal" Margin="14,2,14,2">
                            <Ellipse Width="3"
                                     Height="3"
                                     Fill="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                                     VerticalAlignment="Center"
                                     Margin="0,0,7,0" />
                            <TextBlock Text="{Binding}"
                                       FontSize="12"
                                       VerticalAlignment="Center" />
                          </StackPanel>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </StackPanel>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>

          </StackPanel>
        </ScrollViewer>
      </Grid>
    </Grid>
  </Grid>
</Window>